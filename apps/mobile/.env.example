# Copy this file to `.env` and adjust values for your environment.
# Expo automatically loads `.env` at start time and inlines any
# `EXPO_PUBLIC_*` variable into the JS bundle.

# Base URL of the BooksCompare API.
# - Local dev (default):     http://localhost:8787   (run `pnpm dev:api` in another terminal)
# - Physical device on LAN:  http://<your-mac-ip>:8787
# - Production Worker:       https://bookscompare-api.andrewmmc.workers.dev
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# PostHog analytics. Leave EXPO_PUBLIC_POSTHOG_KEY empty to disable analytics entirely.
# When set, the mobile app initialises posthog-react-native at startup.
EXPO_PUBLIC_POSTHOG_KEY=
# Optional PostHog host (defaults to https://us.i.posthog.com when unset).
# Use https://eu.i.posthog.com or your self-hosted URL if needed.
EXPO_PUBLIC_POSTHOG_HOST=

# Expo/EAS project metadata. Required for local EAS commands such as
# `pnpm exec eas build` and `pnpm exec eas submit`.
EXPO_PROJECT_ID=
EXPO_OWNER=

# App Store release configuration is normally set in GitHub Actions secrets/variables,
# not in local `.env`. Keep this list here for discoverability when debugging releases.
#
# Secrets:
# EXPO_TOKEN=
# EXPO_ASC_API_KEY_BASE64=
# EXPO_APPLE_APP_SPECIFIC_PASSWORD=
#
# Variables:
# EXPO_ASC_APP_ID=
# EXPO_ASC_KEY_ID=
# EXPO_ASC_ISSUER_ID=
# EXPO_APPLE_TEAM_ID=
# EXPO_APPLE_TEAM_TYPE=INDIVIDUAL # or COMPANY_OR_ORGANIZATION
# EXPO_APPLE_ID=
