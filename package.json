{
  "name": "bookscompare",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "pnpm --filter @bookscompare/api dev",
    "deploy:api": "pnpm --filter @bookscompare/api deploy",
    "check:api": "pnpm --filter @bookscompare/api check",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter @bookscompare/api test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3"
  }
}
