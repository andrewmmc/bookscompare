{
  "name": "bookscompare",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": "9.15.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @bookscompare/api dev",
    "dev:mobile": "pnpm --filter @bookscompare/mobile dev",
    "deploy:api": "pnpm --filter @bookscompare/api run deploy",
    "check:api": "pnpm --filter @bookscompare/api check",
    "ios:mobile": "pnpm --filter @bookscompare/mobile ios",
    "android:mobile": "pnpm --filter @bookscompare/mobile android",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter @bookscompare/api test",
    "test:mobile": "pnpm --filter @bookscompare/mobile test",
    "coverage:api": "pnpm --filter @bookscompare/api coverage",
    "coverage:mobile": "pnpm --filter @bookscompare/mobile coverage",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:mobile && pnpm check:api",
    "audit:privacy": "./scripts/audit-privacy.sh",
    "validate:appstore-images": "./scripts/validate-appstore-images.sh",
    "validate:release-notes": "./scripts/validate-release-notes.sh",
    "bump": "./scripts/bump-version.sh patch mobile",
    "bump:minor": "./scripts/bump-version.sh minor mobile",
    "bump:major": "./scripts/bump-version.sh major mobile",
    "bump:api": "./scripts/bump-version.sh patch api",
    "bump:contracts": "./scripts/bump-version.sh patch contracts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-native/eslint-plugin": "^0.85.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
